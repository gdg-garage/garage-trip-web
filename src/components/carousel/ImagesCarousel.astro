---
import css from './ImagesCarousel.module.scss';
import { Image } from 'astro:assets';
import ArrowButton from './ArrowButton.astro';

const mainImages = Object.values(import.meta.glob('/src/assets/images/g::t::7.0.0/*.{jpg,png}', { eager: true }));
const allImages = mainImages.map((mod: any) => mod.default) as ImageMetadata[];
allImages.sort((a, b) => {
  const matchA = a.src.match(/hp_(\d+)/);
  const matchB = b.src.match(/hp_(\d+)/);
  return (matchA ? parseInt(matchA[1]) : 0) - (matchB ? parseInt(matchB[1]) : 0);
});
---

<div class={css.carouselWrapper}>
  <ArrowButton id="scrollLeftBtn" title="scroll left" direction="left" className={css.imageTrack__arrowLeft}/>
  <ArrowButton id="scrollRightBtn" title="scroll right" direction="right" className={css.imageTrack__arrowRight} />

  <div id="imageTrack" class={css.imageTrack}>
    {allImages.map((img) => (
      <div class={css.imageTrack__imageContainer}>
        <Image
          src={img}
          width={img.width}
          height={img.height}
          alt="Event Image"
          class={css.imageTrack__image}
          data-bs-toggle="modal"
          data-bs-target="#imageModal"
          data-full={img.src}
        />
      </div>
    ))}
  </div>
</div>

<div
    class="modal fade"
    id="imageModal"
    tabindex="-1"
    aria-labelledby="imageModalLabel"
    aria-hidden="true"
  >
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-body position-relative p-0">
          <ArrowButton id="modalPrevBtn" title="Previous image" direction="left" variant="modal" className={css.modalBtn__prev} />
          <img src="" id="modalImage" class="img-fluid" />
          <ArrowButton id="modalNextBtn" title="Next image" direction="right" variant="modal" className={css.modalBtn__next} />
        </div>
      </div>
    </div>
</div>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      const track = document.getElementById('imageTrack');
      if (!track) {
        console.error('Missing image track element');
        return;
      }
      // Modal swap logic
      const modalImage = document.getElementById('modalImage');
      const imageElements = Array.from(track.getElementsByTagName('img'));
      let currentImageIndex = -1;

      imageElements.forEach(function (image, index) {
        image.addEventListener('click', function () {
          currentImageIndex = index;
          modalImage.src = image.getAttribute('data-full') || image.src;
        });
      });

      function navigateImage(direction) {
        if (currentImageIndex === -1) return;
        if (direction === 'prev') {
          currentImageIndex = (currentImageIndex - 1 + imageElements.length) % imageElements.length;
        } else {
          currentImageIndex = (currentImageIndex + 1) % imageElements.length;
        }
        const newImage = imageElements[currentImageIndex];
        modalImage.src = newImage.getAttribute('data-full') || newImage.src;
      }

      // Modal keyboard navigation logic
      document.addEventListener('keydown', function(event) {
        // Find if modal is open (using Bootstrap 'show' class convention)
        const modal = document.getElementById('imageModal');
        if (modal && modal.classList.contains('show') && currentImageIndex !== -1) {
          if (event.key === 'ArrowLeft') {
            navigateImage('prev');
          } else if (event.key === 'ArrowRight') {
            navigateImage('next');
          }
        }
      });

      // Modal button navigation logic
      const prevBtn = document.getElementById('modalPrevBtn');
      const nextBtn = document.getElementById('modalNextBtn');
      if (prevBtn) prevBtn.addEventListener('click', function() { navigateImage('prev'); });
      if (nextBtn) nextBtn.addEventListener('click', function() { navigateImage('next'); });

      // Carousel navigation logic

      const leftBtn = document.getElementById('scrollLeftBtn');
      const rightBtn = document.getElementById('scrollRightBtn');

      let timeoutId = null;
      function checkScrollPosition(timeout = 350) {
        clearTimeout(timeoutId);
        timeoutId = setTimeout(() => {
          if (track.scrollLeft === 0) {
            leftBtn.setAttribute('disabled', 'true');
          } else {
            leftBtn.removeAttribute('disabled');
          }
          if (track.scrollWidth === track.scrollLeft + track.clientWidth) {
            rightBtn.setAttribute('disabled', 'true');
          } else {
            rightBtn.removeAttribute('disabled');
          }
        }, timeout);
      }

      track.addEventListener('scroll', checkScrollPosition);

      function calculateScrollAmount() {
        const gap = 15; // Assuming a fixed gap between images
        const images = Array.from(track.getElementsByTagName('img'));
        const containerWidth = track.clientWidth;
        let sum = 0;
        for (const image of images) {
          const remainingSpace = containerWidth - sum;
          if (image.width > remainingSpace) {
            break;
          }
          sum += image.width + gap;
        }
        return sum;
      }

      /**
       * scrolls
       * @param {'left'| 'right'} direction
       */
      function handleScroll(direction) {
        const scrollAmount = direction === 'left' ? -calculateScrollAmount() : calculateScrollAmount();
        track.scrollTo({ left: track.scrollLeft + scrollAmount, behavior: 'smooth' });
      }

      leftBtn.addEventListener('click', function() {
        handleScroll('left');
      });
      rightBtn.addEventListener('click', function() {
        handleScroll('right');
      });

      checkScrollPosition();
    });
</script>
